<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Kalkulator iOS + Dark Mode Toggle</title>
  <style>
    :root {
      --bg-color: #f5f5f7;
      --calc-bg: #ffffff;
      --display-bg: #f1f2f6;
      --display-color: #000;
      --btn-bg: #d4d4d2;
      --btn-text: #000;
      --btn-operator: #ff9500;
      --btn-equal: #34c759;
      --btn-clear: #ff3b30;
      --history-color: #888;
    }

    .dark-mode {
      --bg-color: #1c1c1e;
      --calc-bg: #2c2c2e;
      --display-bg: #3a3a3c;
      --display-color: #fff;
      --btn-bg: #505050;
      --btn-text: #fff;
      --btn-operator: #ff9500;
      --btn-equal: #30d158;
      --btn-clear: #ff453a;
      --history-color: #aaa;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: 'SF Pro Display', 'Segoe UI', sans-serif;
      background-color: var(--bg-color);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      transition: background-color 0.3s ease;
    }

    .mode-toggle {
      position: absolute;
      top: 20px;
      right: 20px;
      font-size: 24px;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--btn-text);
      transition: color 0.3s ease;
    }

    .calculator {
      background-color: var(--calc-bg);
      border-radius: 30px;
      padding: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
      width: 100%;
      max-width: 360px;
      transition: background-color 0.3s ease;
    }

    #display {
      width: 100%;
      height: 70px;
      font-size: 32px;
      text-align: right;
      padding: 15px;
      margin-bottom: 10px;
      border: none;
      border-radius: 20px;
      background-color: var(--display-bg);
      color: var(--display-color);
      box-sizing: border-box;
      transition: all 0.3s ease;
    }

    .history {
      font-size: 14px;
      color: var(--history-color);
      text-align: right;
      margin-bottom: 10px;
      min-height: 18px;
      font-style: italic;
      transition: color 0.3s ease;
    }

    .buttons {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 15px;
    }

    .buttons button {
      height: 65px;
      font-size: 22px;
      border: none;
      border-radius: 50%;
      background-color: var(--btn-bg);
      color: var(--btn-text);
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .buttons button:active {
      transform: scale(0.95);
      filter: brightness(1.1);
    }

    .buttons .operator {
      background-color: var(--btn-operator);
      color: #fff;
    }

    .buttons .equal {
      background-color: var(--btn-equal);
      color: #fff;
      grid-column: span 2;
      border-radius: 50px;
    }

    .buttons .clear {
      background-color: var(--btn-clear);
      color: #fff;
    }

    .buttons .zero {
      grid-column: span 2;
      border-radius: 50px;
    }

  </style>
</head>
<body>
  <!-- Tombol Mode Terang/Gelap -->
  <button class="mode-toggle" onclick="toggleMode()" id="modeToggle">🌙</button>

  <div class="calculator">
    <input type="text" id="display" readonly placeholder="0" />
    <div class="history" id="history"></div>

    <div class="buttons">
      <button onclick="clearDisplay()" class="clear">AC</button>
      <button onclick="appendValue('%')" class="operator">%</button>
      <button onclick="appendValue('/')" class="operator">÷</button>
      <button onclick="appendValue('*')" class="operator">×</button>

      <button onclick="appendValue('7')">7</button>
      <button onclick="appendValue('8')">8</button>
      <button onclick="appendValue('9')">9</button>
      <button onclick="appendValue('-')" class="operator">−</button>

      <button onclick="appendValue('4')">4</button>
      <button onclick="appendValue('5')">5</button>
      <button onclick="appendValue('6')">6</button>
      <button onclick="appendValue('+')" class="operator">+</button>

      <button onclick="appendValue('1')">1</button>
      <button onclick="appendValue('2')">2</button>
      <button onclick="appendValue('3')">3</button>
      <button onclick="calculate()" class="equal">=</button>

      <button onclick="appendValue('0')" class="zero">0</button>
      <button onclick="appendValue('.')">.</button>
    </div>
  </div>

  <script>
    const display = document.getElementById("display");
    const history = document.getElementById("history");
    const body = document.body;
    const modeToggle = document.getElementById("modeToggle");

    function vibrate(ms = 50) {
      if (navigator.vibrate) navigator.vibrate(ms);
    }

    function appendValue(value) {
      vibrate();
      if (display.value === "0" || display.value === "Error") {
        display.value = value;
      } else {
        display.value += value;
      }
    }

    function clearDisplay() {
      vibrate();
      display.value = "";
      history.textContent = "";
    }

    function calculate() {
      vibrate();
      try {
        const result = eval(display.value);
        history.textContent = display.value + " =";
        display.value = result;
      } catch (e) {
        display.value = "Error";
      }
    }

    function toggleMode() {
      body.classList.toggle("dark-mode");
      const isDark = body.classList.contains("dark-mode");
      modeToggle.textContent = isDark ? "🌞" : "🌙";
      localStorage.setItem("theme", isDark ? "dark" : "light");
    }

    // Load saved theme
    (function loadTheme() {
      const savedTheme = localStorage.getItem("theme");
      if (savedTheme === "dark") {
        body.classList.add("dark-mode");
        modeToggle.textContent = "🌞";
      } else {
        modeToggle.textContent = "🌙";
      }
    })();
  </script>
</body>
</html>
